<%# One selectable entry in Lexxy's @-mention prompt. `search` is what Lexxy
    filters against as the user types; `sgid` is the signed global id Action
    Text stores so the mention resolves back to this exact User (no handle
    re-parsing). The editor template reuses the canonical mention partial so the
    inserted pill matches how the sent message renders. %>
<lexxy-prompt-item search="<%= "#{user.mention_handle} #{user.mention_label}" %>"
                   sgid="<%= user.attachable_sgid %>">
  <template type="menu">
    <span class="font-medium text-base-color"><%= user.mention_label %></span>
    <span class="text-xs text-muted-color">@<%= user.mention_handle %></span>
  </template>
  <template type="editor"><%= render "users/user", user: user %></template>
</lexxy-prompt-item>
