<%# Fixed left sidebar for signed-in app pages. Pure markup — every field
    comes from @sidebar (SidebarFacade), assembled by ApplicationController's
    `prepare_sidebar` before_action. On <md it lives as an off-canvas
    drawer driven by `sidebar_controller.js`; at md+ it pins to the left
    edge via `md:fixed md:inset-y-0 md:w-64`. %>
<% return if @sidebar.nil? %>

<%# Backdrop overlay — only visible when the drawer is open on mobile. %>
<div data-sidebar-target="overlay"
     data-action="click->sidebar#close"
     class="fixed inset-0 z-40 hidden bg-zinc-900/60 backdrop-blur-sm md:hidden"
     aria-hidden="true"></div>

<aside id="sidebar-panel"
       data-sidebar-target="panel"
       class="fixed inset-y-0 left-0 z-50 hidden w-64 -translate-x-full transform border-r border-surface bg-surface-raised transition-transform duration-200 ease-out md:fixed md:flex md:translate-x-0"
       aria-label="Primary navigation">
  <div class="flex h-full w-full flex-col">

    <%# ── Brand + close (mobile only) ──────────────────────────────── %>
    <div class="flex h-14 shrink-0 items-center justify-between border-b border-surface px-4">
      <%= link_to @sidebar.brand_href,
            data: main_frame_data,
            class: "flex min-w-0 items-center gap-2 rounded-md outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
        <%= render "shared/brand_mark" %>
      <% end %>

      <button type="button"
              data-action="click->sidebar#close"
              class="btn-base btn-ghost btn-icon-sm md:hidden text-zinc-600 dark:text-zinc-400"
              aria-label="Close navigation">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 0 1 1.414 0L10 8.586l4.293-4.293a1 1 0 1 1 1.414 1.414L11.414 10l4.293 4.293a1 1 0 0 1-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 0 1-1.414-1.414L8.586 10 4.293 5.707a1 1 0 0 1 0-1.414Z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    <%# ── Primary nav ──────────────────────────────────────────────── %>
    <nav class="flex-1 overflow-y-auto px-3 py-4">
      <ul class="flex flex-col gap-0.5">
        <% @sidebar.primary_nav.each do |item| %>
          <li>
            <%= link_to item.href,
                  data: main_frame_data,
                  class: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-base-color transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800" do %>
              <%= render "shared/nav_icon", icon: item.icon %>
              <%= item.label %>
            <% end %>
          </li>
        <% end %>

        <% if @sidebar.show_teams_section? %>
          <li data-controller="disclosure">
            <button type="button"
                    data-action="click->disclosure#toggle"
                    data-disclosure-target="trigger"
                    aria-controls="sidebar-teams-panel"
                    aria-expanded="false"
                    class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-base-color transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800">
              <%= render "shared/nav_icon", icon: :teams %>
              <span class="flex-1 text-left">Teams</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                   data-disclosure-target="chevron"
                   class="h-4 w-4 text-muted-color transition-transform duration-150">
                <path fill-rule="evenodd" d="M5.22 7.22a.75.75 0 0 1 1.06 0L10 10.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 8.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </button>

            <div id="sidebar-teams-panel"
                 data-disclosure-target="panel"
                 class="mt-0.5 hidden pl-9">
              <% if @sidebar.teams? %>
                <ul class="flex flex-col gap-0.5 border-l border-surface pl-3">
                  <% @sidebar.teams.each do |team| %>
                    <li>
                      <%= link_to team.name, team.href,
                            data: main_frame_data,
                            class: "block truncate rounded-md px-2 py-1.5 text-sm text-muted-color transition-colors hover:bg-zinc-100 hover:text-base-color dark:hover:bg-zinc-800" %>
                    </li>
                  <% end %>
                  <li class="pt-1">
                    <%= link_to "View all teams", @sidebar.teams_index_href,
                          data: main_frame_data,
                          class: "block rounded-md px-2 py-1.5 text-xs font-medium text-brand-600 hover:underline dark:text-brand-400" %>
                  </li>
                </ul>
              <% else %>
                <p class="px-2 py-1.5 text-xs text-muted-color">
                  You're not on any team yet.
                </p>
                <%= link_to "Browse teams", @sidebar.teams_index_href,
                      data: main_frame_data,
                      class: "block px-2 py-1 text-xs font-medium text-brand-600 hover:underline dark:text-brand-400" %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </nav>

    <%# ── Footer: theme toggle + account + logout ──────────────────── %>
    <div class="shrink-0 border-t border-surface px-3 py-3">
      <div class="mb-2 flex items-center justify-end">
        <button type="button"
                data-action="click->theme#toggle"
                class="btn-base btn-ghost btn-icon-sm text-zinc-600 dark:text-zinc-400"
                aria-label="Toggle colour theme">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="hidden h-5 w-5 dark:block">
            <path d="M10 2a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 2ZM10 15a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 15ZM10 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM15.657 5.404a.75.75 0 1 0-1.06-1.06l-1.061 1.06a.75.75 0 0 0 1.06 1.06l1.06-1.06ZM6.464 14.596a.75.75 0 1 0-1.06-1.06l-1.06 1.06a.75.75 0 0 0 1.06 1.06l1.06-1.06ZM18 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 18 10ZM5 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 5 10ZM14.596 15.657a.75.75 0 0 0 1.06-1.06l-1.06-1.061a.75.75 0 1 0-1.06 1.06l1.06 1.06ZM5.404 6.464a.75.75 0 0 0 1.06-1.06L5.404 4.343a.75.75 0 0 0-1.06 1.06l1.06 1.06Z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="block h-5 w-5 dark:hidden">
            <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 0 1 .26.77 7 7 0 0 0 9.958 7.967.75.75 0 0 1 1.067.853A8.5 8.5 0 1 1 6.647 1.921a.75.75 0 0 1 .808.083Z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>

      <%= link_to @sidebar.account_href,
            data: main_frame_data,
            class: "flex items-center gap-3 rounded-lg px-2 py-2 text-sm transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800" do %>
        <%= user_avatar_tag(@sidebar.avatar_user, variant: :thumb, css: "h-9 w-9") %>
        <span class="min-w-0 flex-1">
          <span class="block truncate text-sm font-medium text-zinc-900 dark:text-zinc-100"><%= @sidebar.display_name %></span>
          <span class="block truncate text-xs text-muted-color">Account settings</span>
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-muted-color">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 0 1 .02-1.06L11.168 10 7.23 6.29a.75.75 0 1 1 1.04-1.08l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.06-.02Z" clip-rule="evenodd" />
        </svg>
      <% end %>

      <%= link_to @sidebar.logout_href,
            data: {
              turbo_frame: "_top",
              turbo_method: :delete,
              turbo_confirm: "Sign out of Code Nest?",
              confirm_title: "Sign out",
              confirm_button: "Sign out",
              confirm_variant: "primary"
            },
            class: "mt-1 flex items-center gap-3 rounded-lg px-2 py-2 text-sm font-medium text-rose-600 transition-colors hover:bg-rose-50 dark:text-rose-400 dark:hover:bg-rose-500/10" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M3 4.25A2.25 2.25 0 0 1 5.25 2h5.5A2.25 2.25 0 0 1 13 4.25v2a.75.75 0 0 1-1.5 0v-2a.75.75 0 0 0-.75-.75h-5.5a.75.75 0 0 0-.75.75v11.5c0 .414.336.75.75.75h5.5a.75.75 0 0 0 .75-.75v-2a.75.75 0 0 1 1.5 0v2A2.25 2.25 0 0 1 10.75 18h-5.5A2.25 2.25 0 0 1 3 15.75V4.25Z" clip-rule="evenodd" />
          <path fill-rule="evenodd" d="M19 10a.75.75 0 0 0-.22-.53l-3.25-3.25a.75.75 0 1 0-1.06 1.06l1.97 1.97H8.75a.75.75 0 0 0 0 1.5h7.69l-1.97 1.97a.75.75 0 1 0 1.06 1.06l3.25-3.25A.75.75 0 0 0 19 10Z" clip-rule="evenodd" />
        </svg>
        Logout
      <% end %>
    </div>
  </div>
</aside>
