<footer class="border-t border-surface bg-surface-raised mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-5">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between text-xs text-muted-color">
      <span>&copy; <%= Date.current.year %> Code Nest &mdash; All rights reserved.</span>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <% if Rails.env.development? %>
          <%= link_to "Design system", design_system_path, class: "btn-link" %>
        <% end %>
        <span>Rails <%= Rails::VERSION::STRING %> &middot; v<%= ENV.fetch("APP_VERSION", "0.1.0") %></span>
      </div>
    </div>
  </div>
</footer>
