<% page_title "Invitations — #{current_organisation.name}" %>

<% content_for :page_actions do %>
  <%= render "components/btn", label: "Send invitation", href: new_invitation_path, variant: :primary, size: :sm %>
<% end %>

<%= render "components/page_header",
      title: "Invitations",
      description: "Outstanding and recently accepted invitations.",
      breadcrumbs: [
        { label: "Dashboard", href: dashboard_path },
        { label: "Invitations" },
      ] %>

<div class="card-grid-2">
  <%= render "components/card", title: "Pending" do %>
    <% if @pending.any? %>
      <ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
        <% @pending.each do |inv| %>
          <li class="py-4 first:pt-0 flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-3 min-w-0">
              <%= email_avatar_tag(inv.email, css: "h-8 w-8") %>
              <div class="min-w-0">
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate"><%= inv.email %></p>
                <p class="text-xs text-muted-color">
                  <% if inv.invited_by %>
                    <span class="inline-flex items-center gap-1.5">
                      <%= user_avatar_tag(inv.invited_by, css: "h-4 w-4 text-[10px]") %>
                      <%= inv.invited_by.email %>
                    </span>
                  <% else %>
                    System
                  <% end %>
                <% if inv.expires_at %>
                  · Expires <%= inv.expires_at.strftime("%-d %b %Y") %>
                <% else %>
                  · No expiry
                <% end %>
                </p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= badge_tag inv.invite_admin? ? "Admin" : "Member", variant: inv.invite_admin? ? :brand : :neutral %>
              <%= button_to "Revoke",
                    invitation_path(inv),
                    method: :delete,
                    data: { turbo_confirm: "Revoke the invitation for #{inv.email}?" },
                    class: "btn-base btn-ghost btn-sm" %>
            </div>
          </li>
        <% end %>
      </ul>
      <%= pagination_tag(@pagy_pending) %>
    <% else %>
      <%= render "components/empty_state",
            icon: :inbox,
            title: "No pending invitations",
            description: "Send a new invitation to add a teammate." %>
    <% end %>
  <% end %>

  <%= render "components/card", title: "Recently accepted" do %>
    <% if @accepted.any? %>
      <ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
        <% @accepted.each do |inv| %>
          <li class="py-4 first:pt-0">
            <div class="flex items-center gap-3">
              <%= email_avatar_tag(inv.email, css: "h-8 w-8") %>
              <div>
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100"><%= inv.email %></p>
                <p class="text-xs text-muted-color">Accepted <%= inv.accepted_at&.strftime("%-d %b %Y") %></p>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
      <%= pagination_tag(@pagy_accepted) %>
    <% else %>
      <p class="text-sm text-muted-color">No invitations have been accepted yet.</p>
    <% end %>
  <% end %>
</div>
