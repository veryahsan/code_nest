<% page_title "New group — Messages" %>

<%= render "components/page_header",
      title: "New group",
      description: "Create a group conversation (up to #{Conversation::GROUP_CAPACITY} people).",
      breadcrumbs: [
        { label: "Messages", href: messages_path },
        { label: "New group" },
      ] %>

<div class="flex justify-center">
  <%= render "components/card", extra_class: "w-full max-w-2xl" do %>
    <%= form_with url: conversations_path, method: :post, class: "space-y-6", local: true do |f| %>
      <%= render "components/form_group", label: "Group name", for_id: "title", required: true do %>
        <%= f.text_field :title, id: "title", autofocus: true, class: input_classes %>
      <% end %>

      <%= render "components/form_group",
            label: "Members",
            hint: "Pick up to #{Conversation::GROUP_CAPACITY - 1} people. You're added automatically." do %>
        <% if @contacts.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-72 overflow-y-auto">
            <% @contacts.each do |u| %>
              <label class="inline-flex items-center gap-2 text-sm">
                <%= check_box_tag "user_ids[]", u.id, false, class: "rounded border-zinc-300 dark:border-zinc-700" %>
                <span class="truncate"><%= u.email %></span>
              </label>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-muted-color">No one else is in your organisation yet.</p>
        <% end %>
      <% end %>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <%= link_to "Cancel", messages_path, class: "btn-link text-sm font-medium" %>
        <%= render "components/btn", label: "Create group", type: :submit, variant: :primary %>
      </div>
    <% end %>
  <% end %>
</div>
