<% page_title "#{@conversation.display_title(current_user)} — Messages" %>

<% if @thread_only %>
  <%# Row click in the list: swap only the thread frame in place. %>
  <%= render "conversations/thread",
        conversation: @conversation,
        messages: @messages,
        readers: @readers %>
<% else %>
  <%# Deep link / reload: render the full split-pane shell so the conversation
      list on the left is preserved, with this conversation open on the right. %>
  <%= render "conversations/layout",
        conversations: @conversations,
        contacts: @contacts,
        last_messages: @last_messages,
        active_id: @conversation.id,
        right_partial: "conversations/thread",
        right_locals: { conversation: @conversation, messages: @messages, readers: @readers } %>
<% end %>
