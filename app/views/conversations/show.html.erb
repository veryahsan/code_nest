<% page_title "#{@conversation.display_title(current_user)} — Messages" %>

<%= render "components/page_header",
      title: @conversation.display_title(current_user),
      description: @conversation.group? ? "Group · #{pluralize(@conversation.conversation_participants.size, 'member')}" : "Direct message",
      breadcrumbs: [
        { label: "Messages", href: messages_path },
        { label: @conversation.display_title(current_user) },
      ] %>

<div data-controller="conversation"
     data-conversation-id-value="<%= @conversation.id %>"
     data-conversation-user-id-value="<%= current_user.id %>">
  <%# Avatars the client clones into read-receipt rows; keyed by participant id. %>
  <div data-conversation-target="roster" class="hidden" aria-hidden="true">
    <% @conversation.conversation_participants.includes(user: :employee).each do |cp| %>
      <span data-roster-user="<%= cp.user_id %>" title="<%= user_avatar_label(cp.user) %>" class="inline-flex"><%= user_avatar_tag(cp.user, css: "h-5 w-5", text: "text-[9px]") %></span>
    <% end %>
  </div>
  <%= render "components/card", padded: false do %>
    <div data-conversation-target="list"
         class="flex h-[60vh] flex-col gap-3 overflow-y-auto p-4">
      <% if @messages.any? %>
        <% @messages.each do |message| %>
          <% mine = message.user_id == current_user.id %>
          <div class="flex flex-col <%= mine ? 'items-end' : 'items-start' %>" data-message-id="<%= message.id %>">
            <span class="px-1 text-xs text-muted-color"><%= mine ? "You" : message.sender_label %></span>
            <div class="<%= mine ? 'mt-0.5 max-w-[75%] rounded-2xl rounded-br-sm bg-brand-600 px-3 py-2 text-sm text-white' : 'mt-0.5 max-w-[75%] rounded-2xl rounded-bl-sm bg-surface-raised border border-surface px-3 py-2 text-sm text-base-color' %>">
              <%= message.body %>
            </div>
            <div data-receipts-for="<%= message.id %>" class="flex flex-wrap gap-1 px-1 mt-1.5">
              <% if message == @messages.last %>
                <% @readers.each do |reader| %>
                  <span data-receipt-user="<%= reader.id %>" title="<%= user_avatar_label(reader) %>" class="inline-flex"><%= user_avatar_tag(reader, css: "h-5 w-5", text: "text-[9px]") %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div data-conversation-target="empty" class="m-auto text-center">
          <p class="text-sm text-muted-color">No messages yet. Say hello!</p>
        </div>
      <% end %>
    </div>

    <div class="border-t border-surface p-3">
      <%= form_with url: conversation_messages_path(@conversation),
            scope: :message,
            method: :post,
            data: { conversation_target: "form", action: "submit->conversation#submit" },
            class: "flex items-center gap-2" do |f| %>
        <%= f.text_field :body,
              placeholder: "Write a message…",
              autocomplete: "off",
              data: { conversation_target: "input" },
              class: input_classes %>
        <%= render "components/btn", label: "Send", type: :submit, variant: :primary, size: :sm %>
      <% end %>
    </div>
  <% end %>
</div>
