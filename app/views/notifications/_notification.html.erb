<%# Single notification row, used both for the server-seeded sidebar dropdown
    and the full-page list. The matching live-pushed rows are built in
    notifications_controller.js, so keep the structure in sync with that. %>
<%
  notifiable  = notification.notifiable
  actor_label = notification.actor ? Conversation.participant_label(notification.actor) : "Someone"

  case notification.kind
  when "user_mentioned"
    lead, kind_caption = actor_label, "mentioned you"
    body_preview = notifiable.is_a?(Message) ? notifiable.body.to_s.truncate(80) : ""
  when "invitation_accepted"
    lead, kind_caption = actor_label, "accepted your invitation"
    body_preview = notifiable.is_a?(Invitation) ? notifiable.email : ""
  when "project_membership_created"
    lead, kind_caption = "You were added to #{notifiable.is_a?(Project) ? notifiable.name : "a project"}", ""
    body_preview = ""
  else
    lead, kind_caption = actor_label, "sent a message"
    body_preview = notifiable.is_a?(Message) ? notifiable.body.to_s.truncate(80) : ""
  end
%>
<%= link_to read_notification_path(notification),
      data: main_frame_data("turbo-method" => :patch,
                            "action" => "click->notifications#markReadOptimistic",
                            "notification-id" => notification.id,
                            "read" => notification.read?),
      class: "flex items-start gap-2.5 px-4 py-3 text-sm transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800 #{'bg-brand-50/60 dark:bg-brand-500/10' unless notification.read?}" do %>
  <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full <%= notification.read? ? 'bg-transparent' : 'bg-brand-500' %>"
        aria-hidden="true"></span>
  <span class="min-w-0 flex-1">
    <span class="block truncate font-medium text-base-color"><%= lead %><% if kind_caption.present? %> <span class="font-normal text-muted-color"><%= kind_caption %></span><% end %></span>
    <% if body_preview.present? %>
      <span class="block truncate text-xs text-muted-color"><%= body_preview %></span>
    <% end %>
    <span class="block text-xs text-muted-color"><%= time_ago_in_words(notification.created_at) %> ago</span>
  </span>
<% end %>
