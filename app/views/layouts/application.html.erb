<!DOCTYPE html>
<html class="h-full bg-surface antialiased"
      data-controller="theme"
      data-theme-default-value="system">
  <head>
    <%= render "shared/app_head" %>
  </head>

  <body class="min-h-full bg-surface text-base-color">
    <% if user_signed_in? %>
      <div class="flex min-h-full flex-col">
        <%= render "shared/menu_capsule" %>

        <main class="flex-1 relative z-0 isolate">
          <div class="mx-auto max-w-screen-2xl px-4 sm:px-6 lg:px-8 pb-8">
            <%= main_content_frame do %>
              <%= yield %>
            <% end %>
          </div>
        </main>
      </div>

      <%= render "shared/modal_host" %>
    <% else %>
      <div class="flex min-h-full flex-col">
        <%= render "shared/navbar" %>

        <main class="flex-1 relative z-0 isolate">
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
            <%= render "shared/flash" %>
            <%= yield %>
          </div>
        </main>

        <%= render "shared/footer" %>
      </div>
    <% end %>

    <%= render "shared/confirm_dialog" %>
  </body>
</html>
