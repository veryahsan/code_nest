<%# Layout for show pages opened in the generic overlay. Selected by
    ApplicationController#resolved_layout for actions declared with
    `show_in_modal`, in two situations:

      1. Frame request (a link with data-turbo-frame="modal"): emit ONLY the
         <turbo-frame id="modal"> overlay; Turbo swaps it into the persistent
         host in the application layout, whose modal-frame controller reveals /
         locks / closes the overlay.

      2. Direct / full load (hard reload, bookmark, typed URL): there is no
         persistent host yet, so emit the full HTML document with the signed-in
         chrome and an empty content area, then seed the modal host with the
         overlay so the page IS the modal. %>

<% overlay = render("shared/modal_overlay", body: capture { yield }) %>

<% if turbo_frame_request? %>
  <%= turbo_frame_tag "modal" do %>
    <%= overlay %>
  <% end %>
<% else %>
  <!DOCTYPE html>
  <html class="h-full bg-surface antialiased"
        data-controller="theme"
        data-theme-default-value="system">
    <head>
      <%= render "shared/app_head" %>
    </head>

    <body class="min-h-full bg-surface text-base-color">
      <div class="flex min-h-full flex-col">
        <%= render "shared/menu_capsule" %>

        <%# Empty content area behind the overlay. The modal is the page. %>
        <main class="flex-1 relative z-0 isolate"></main>
      </div>

      <%# Closing a deep-loaded modal has no in-app history to fall back to;
          send the user to the parent collection (the show path minus its id). %>
      <%= render "shared/modal_host",
            body: overlay,
            fallback_url: request.path.sub(%r{/[^/]+/?\z}, "").presence || "/" %>

      <%= render "shared/confirm_dialog" %>
    </body>
  </html>
<% end %>
