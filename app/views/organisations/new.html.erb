<% page_title "Create organisation — Code Nest" %>

<div class="flex justify-center">
  <%= render "components/card",
        title: "Create your organisation",
        description: "You'll be the organisation admin. Anyone signing up later from your email domain will join automatically.",
        extra_class: "w-full max-w-lg" do %>

    <% if @organisation.errors.any? %>
      <%= render "components/alert",
            variant: :danger,
            title: "#{pluralize(@organisation.errors.count, 'issue')} prevented saving",
            message: @organisation.errors.full_messages.to_sentence,
            dismissible: false %>
    <% end %>

    <%= form_with model: @organisation, url: organisations_path, method: :post, class: "space-y-4" do |f| %>
      <%= render "components/form_group",
            label: "Organisation name",
            for_id: "organisation_name",
            hint: "Shown across the app (e.g. your company or team name).",
            required: true,
            error: @organisation.errors[:name].first do %>
        <%= f.text_field :name,
              id: "organisation_name",
              autocomplete: "organization",
              autofocus: true,
              class: input_classes(@organisation.errors[:name].any?) %>
      <% end %>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <%= link_to "Back to dashboard", dashboard_path, class: "btn-link text-sm font-medium" %>
        <%= render "components/btn", label: "Create organisation", type: :submit, variant: :primary %>
      </div>
    <% end %>
  <% end %>
</div>
