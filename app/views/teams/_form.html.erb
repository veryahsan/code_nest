<%= form_with model: team, url: form_url, method: form_method, class: "space-y-4" do |f| %>
  <% if team.errors.any? %>
    <%= render "components/alert",
          variant: :danger,
          title: "#{pluralize(team.errors.count, 'issue')} prevented saving",
          message: team.errors.full_messages.to_sentence,
          dismissible: false %>
  <% end %>

  <%= render "components/form_group",
        label: "Name",
        for_id: "team_name",
        required: true,
        error: team.errors[:name].first do %>
    <%= f.text_field :name,
          id: "team_name",
          autofocus: true,
          class: input_classes(team.errors[:name].any?) %>
  <% end %>

  <%= render "components/form_group",
        label: "Slug",
        for_id: "team_slug",
        hint: "Optional. Defaults to a normalised version of the name.",
        error: team.errors[:slug].first do %>
    <%= f.text_field :slug,
          id: "team_slug",
          class: input_classes(team.errors[:slug].any?) %>
  <% end %>

  <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
    <%= link_to "Cancel", teams_path, class: "btn-link text-sm font-medium" %>
    <%= render "components/btn", label: submit_label, type: :submit, variant: :primary %>
  </div>
<% end %>
