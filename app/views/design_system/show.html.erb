<% page_title "Design System — Code Nest" %>

<%# ────────────────────────────────────────────────────────────────────────────
    Code Nest Design System Showcase
    Demonstrates every reusable component available across the application.
    This page is intended for development reference and portfolio demonstration.
──────────────────────────────────────────────────────────────────────────────── %>

<%= render "components/page_header",
      title: "Design System",
      description: "Every component, pattern, and token used across Code Nest — all in one place.",
      breadcrumbs: [
        { label: "Home", href: root_path },
        { label: "Design System", href: design_system_path },
      ] %>

<%# ── Colour Palette ──────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Colour Palette</h2>

  <div class="space-y-3">
    <%# Brand %>
    <div>
      <p class="text-xs text-muted-color mb-1.5">Brand (violet)</p>
      <div class="flex gap-1 flex-wrap">
        <% [50, 100, 200, 300, 400, 500, 600, 700, 800, 900, 950].each do |shade| %>
          <div class="flex flex-col items-center gap-1">
            <div class="h-9 w-9 rounded-md ring-1 ring-black/5 bg-brand-<%= shade %>"></div>
            <span class="text-[10px] text-muted-color"><%= shade %></span>
          </div>
        <% end %>
      </div>
    </div>
    <%# Semantic %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% { "Success" => "emerald", "Warning" => "amber", "Danger" => "rose", "Info" => "sky" }.each do |name, cls| %>
        <div>
          <p class="text-xs text-muted-color mb-1"><%= name %></p>
          <div class="flex gap-1">
            <div class="h-8 w-8 rounded-md bg-<%= cls %>-100 ring-1 ring-black/5"></div>
            <div class="h-8 w-8 rounded-md bg-<%= cls %>-500 ring-1 ring-black/5"></div>
            <div class="h-8 w-8 rounded-md bg-<%= cls %>-700 ring-1 ring-black/5"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Buttons ─────────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Buttons</h2>

  <%= render "components/card", title: "Variants" do %>
    <div class="flex flex-wrap gap-3">
      <%= render "components/btn", label: "Primary",   variant: :primary   %>
      <%= render "components/btn", label: "Secondary", variant: :secondary %>
      <%= render "components/btn", label: "Danger",    variant: :danger    %>
      <%= render "components/btn", label: "Ghost",     variant: :ghost     %>
      <%= render "components/btn", label: "Link",      variant: :link      %>
    </div>
  <% end %>

  <%= render "components/card", title: "Sizes", extra_class: "mt-3" do %>
    <div class="flex flex-wrap items-end gap-3">
      <%= render "components/btn", label: "Small",  variant: :primary, size: :sm %>
      <%= render "components/btn", label: "Medium", variant: :primary, size: :md %>
      <%= render "components/btn", label: "Large",  variant: :primary, size: :lg %>
    </div>
  <% end %>

  <%= render "components/card", title: "States", extra_class: "mt-3" do %>
    <div class="flex flex-wrap gap-3">
      <%= render "components/btn", label: "Disabled", variant: :primary,   disabled: true %>
      <%= render "components/btn", label: "Loading",  variant: :primary,   loading: true  %>
      <%= render "components/btn", label: "Disabled", variant: :secondary, disabled: true %>
    </div>
  <% end %>

  <%= render "components/card", title: "With Loader Controller (submit)", extra_class: "mt-3" do %>
    <button type="button"
            class="btn-base btn-primary btn-md"
            data-controller="loader"
            data-loader-label-value="Saving…"
            data-action="click->loader#start">
      Save project
    </button>
    <p class="mt-2 text-xs text-muted-color">Click to see the loading state. Resets after 3 s (timeout demo).</p>
  <% end %>
</section>

<%# ── Badges ──────────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Badges</h2>

  <%= render "components/card" do %>
    <div class="flex flex-wrap gap-2">
      <%= badge_tag "Neutral",  variant: :neutral %>
      <%= badge_tag "Brand",    variant: :brand   %>
      <%= badge_tag "Success",  variant: :success %>
      <%= badge_tag "Warning",  variant: :warning %>
      <%= badge_tag "Danger",   variant: :danger  %>
      <%= badge_tag "Info",     variant: :info    %>
    </div>
    <div class="flex flex-wrap gap-2 mt-3">
      <%= badge_tag "Active",   variant: :success, dot: true %>
      <%= badge_tag "Paused",   variant: :warning, dot: true %>
      <%= badge_tag "Archived", variant: :neutral, dot: true %>
      <%= badge_tag "Error",    variant: :danger,  dot: true %>
    </div>
  <% end %>
</section>

<%# ── Alerts ──────────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Alerts</h2>

  <div class="space-y-3">
    <%= alert_tag "Project created successfully. You can now add team members.", variant: :success %>
    <%= alert_tag "Your free plan expires in 3 days. Upgrade to keep access.", variant: :warning %>
    <%= alert_tag "Could not connect to the remote resource. Check your credentials.", variant: :danger %>
    <%= alert_tag "This integration requires Google Drive access to be re-authorised.", variant: :info %>

    <%= render "components/alert",
          variant: :danger,
          title: "Deployment failed",
          message: "The build step exited with code 1. See logs for details.",
          dismissible: true %>

    <%= render "components/alert",
          variant: :success,
          title: "Migration complete",
          message: "All 142 records were processed without errors.",
          dismissible: true %>
  </div>
</section>

<%# ── Cards ───────────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Cards</h2>

  <div class="card-grid-2">
    <%= render "components/card", title: "Plain card (border only)" do %>
      <p class="text-sm text-muted-color">A card with a header title and default body padding.</p>
    <% end %>

    <%= render "components/card",
          title: "Shadowed card",
          description: "Optional subtitle",
          shadow: true do %>
      <p class="text-sm text-muted-color">A card with the <code class="text-xs bg-zinc-100 dark:bg-zinc-800 px-1 py-0.5 rounded">shadow: true</code> option.</p>
    <% end %>

    <%= render "components/card", padded: false do %>
      <div class="card-header">
        <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">Manual sections</h3>
      </div>
      <div class="card-body">
        <p class="text-sm text-muted-color">Use <code class="text-xs bg-zinc-100 dark:bg-zinc-800 px-1 py-0.5 rounded">card-header</code>, <code class="text-xs bg-zinc-100 dark:bg-zinc-800 px-1 py-0.5 rounded">card-body</code>, <code class="text-xs bg-zinc-100 dark:bg-zinc-800 px-1 py-0.5 rounded">card-footer</code> classes directly when you need more control.</p>
      </div>
      <div class="card-footer flex justify-end gap-2">
        <%= render "components/btn", label: "Cancel", variant: :ghost, size: :sm %>
        <%= render "components/btn", label: "Confirm", variant: :primary, size: :sm %>
      </div>
    <% end %>
  </div>
</section>

<%# ── Spinners ─────────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Spinners</h2>

  <%= render "components/card" do %>
    <div class="flex items-center gap-6">
      <%= spinner_tag size: :sm, label: "Loading…" %>
      <%= spinner_tag size: :md, label: "Loading…" %>
      <%= spinner_tag size: :lg, label: "Loading…" %>
      <%= spinner_tag size: :md, color: "text-brand-600" %>
      <%= spinner_tag size: :md, color: "text-success-600" %>
      <%= spinner_tag size: :md, color: "text-danger-600" %>
    </div>
  <% end %>
</section>

<%# ── Empty States ────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Empty States</h2>

  <div class="card-grid-2">
    <%= render "components/card", padded: false do %>
      <%= render "components/empty_state",
            icon: :inbox,
            title: "No projects yet",
            description: "Create your first project to start tracking technologies and documents.",
            action_label: "New project",
            action_href: "#" %>
    <% end %>

    <%= render "components/card", padded: false do %>
      <%= render "components/empty_state",
            icon: :search,
            title: "No results found",
            description: "Try adjusting your search or filters." %>
    <% end %>
  </div>
</section>

<%# ── Modal ───────────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Modal / Popup</h2>

  <%= render "components/card" do %>
    <div class="flex gap-3">
      <button type="button"
              class="btn-base btn-primary btn-md"
              data-action="click->modal#open"
              data-modal-outlet="#demo-modal-confirm">
        Open confirm modal
      </button>
      <button type="button"
              class="btn-base btn-secondary btn-md"
              data-action="click->modal#open"
              data-modal-outlet="#demo-modal-form">
        Open form modal
      </button>
    </div>
    <p class="mt-2 text-xs text-muted-color">Press Esc or click the backdrop to close.</p>
  <% end %>
</section>

<%# ── Form Elements ───────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Form Elements</h2>

  <%= render "components/card", title: "Inputs & Groups" do %>
    <div class="max-w-md space-y-4">
      <%= render "components/form_group",
            label: "Project name",
            for_id: "demo-project-name",
            required: true do %>
        <input id="demo-project-name" type="text" class="input" placeholder="e.g. Code Nest API">
      <% end %>

      <%= render "components/form_group",
            label: "Email address",
            for_id: "demo-email",
            hint: "We'll never share your email." do %>
        <input id="demo-email" type="email" class="input" placeholder="you@example.com">
      <% end %>

      <%= render "components/form_group",
            label: "Error state",
            for_id: "demo-error",
            error: "This field is required." do %>
        <input id="demo-error" type="text" class="input input-error" value="bad input">
      <% end %>

      <%= render "components/form_group",
            label: "Disabled field",
            for_id: "demo-disabled" do %>
        <input id="demo-disabled" type="text" class="input" placeholder="Disabled" disabled>
      <% end %>
    </div>
  <% end %>
</section>

<%# ── Clipboard ───────────────────────────────────────────────────────────── %>
<section class="mb-12">
  <h2 class="text-sm font-semibold text-muted-color uppercase tracking-widest mb-4">Clipboard</h2>

  <%= render "components/card" do %>
    <div class="flex items-center gap-2 max-w-sm"
         data-controller="clipboard"
         data-clipboard-text-value="bundle exec rails quality:all">
      <code class="flex-1 rounded-md bg-zinc-100 dark:bg-zinc-800 px-3 py-2 text-xs font-mono text-zinc-900 dark:text-zinc-100">
        bundle exec rails quality:all
      </code>
      <button type="button"
              data-action="click->clipboard#copy"
              data-clipboard-target="button"
              class="btn-base btn-ghost btn-icon-md shrink-0"
              title="Copy">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M13.887 3.182c.396.037.79.08 1.183.128C16.194 3.45 17 4.414 17 5.517V16.75A2.25 2.25 0 0 1 14.75 19h-9.5A2.25 2.25 0 0 1 3 16.75V5.517c0-1.103.806-2.068 1.93-2.207.393-.048.787-.09 1.183-.128A3.001 3.001 0 0 1 9 1h2c1.373 0 2.531.923 2.887 2.182ZM7.5 4A1.5 1.5 0 0 1 9 2.5h2A1.5 1.5 0 0 1 12.5 4v.5h-5V4Z" clip-rule="evenodd" />
        </svg>
      </button>
      <span data-clipboard-target="feedback"
            class="hidden text-xs text-success-600 dark:text-success-400 font-medium">
        Copied!
      </span>
    </div>
  <% end %>
</section>

<%# ── Modals (off-screen) ─────────────────────────────────────────────────── %>

<%= render "components/modal", id: "demo-modal-confirm", title: "Delete project" do %>
  <p class="text-sm text-muted-color">
    Are you sure you want to delete <strong class="text-zinc-900 dark:text-zinc-100">Alpha Dashboard</strong>?
    This action cannot be undone.
  </p>
  <div class="mt-6 flex justify-end gap-2">
    <button class="btn-base btn-secondary btn-md"
            data-action="click->modal#close"
            data-modal-outlet="#demo-modal-confirm">
      Cancel
    </button>
    <%= render "components/btn", label: "Delete", variant: :danger, size: :md %>
  </div>
<% end %>

<%= render "components/modal", id: "demo-modal-form", title: "Add team member", size: :md do %>
  <div class="space-y-4">
    <%= render "components/form_group",
          label: "Full name",
          for_id: "modal-name",
          required: true do %>
      <input id="modal-name" type="text" class="input" placeholder="Ada Lovelace">
    <% end %>
    <%= render "components/form_group",
          label: "Email address",
          for_id: "modal-email",
          required: true do %>
      <input id="modal-email" type="email" class="input" placeholder="ada@example.com">
    <% end %>
  </div>
  <div class="mt-6 flex justify-end gap-2">
    <button class="btn-base btn-secondary btn-md"
            data-action="click->modal#close"
            data-modal-outlet="#demo-modal-form">
      Cancel
    </button>
    <button class="btn-base btn-primary btn-md"
            data-controller="loader"
            data-loader-label-value="Inviting…"
            data-action="click->loader#start">
      Send invite
    </button>
  </div>
<% end %>
