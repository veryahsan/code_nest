<% page_title "Resend confirmation — Code Nest" %>

<div class="flex justify-center">
  <%= render "components/card",
        title: "Resend confirmation instructions",
        description: "Enter the email you signed up with and we’ll send a fresh confirmation link.",
        extra_class: "w-full max-w-md" do %>

    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "components/form_group",
            label: "Email",
            for_id: "user_email",
            required: true,
            error: resource.errors[:email].first do %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: input_classes(resource.errors[:email].any?) %>
      <% end %>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <%= render "devise/shared/links" %>
        <%= render "components/btn", label: "Resend instructions", type: :submit, variant: :primary %>
      </div>
    <% end %>
  <% end %>
</div>
