<p>Hi <%= @email %>,</p>

<p>Welcome to Code Nest! Confirm your email address to activate your account and finish signing in.</p>

<p>
  <%= link_to "Confirm my email",
        confirmation_url(@resource, confirmation_token: @token),
        style: "display:inline-block;padding:10px 16px;background-color:#4f46e5;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;" %>
</p>

<p style="font-size:12px;color:#6b7280;">
  This link expires in <%= time_ago_in_words(Devise.confirm_within.from_now) %>.
  If the button doesn't work, paste this URL into your browser:<br>
  <%= confirmation_url(@resource, confirmation_token: @token) %>
</p>

<p style="font-size:12px;color:#6b7280;">
  Didn't sign up for Code Nest? You can safely ignore this message.
</p>
