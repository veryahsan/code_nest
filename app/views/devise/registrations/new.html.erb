<% page_title "Sign up — Code Nest" %>

<div class="flex justify-center">
  <%= render "components/card",
        title: "Create your account",
        description: "Sign up with your work email. We’ll connect you to your organisation after you confirm.",
        extra_class: "w-full max-w-lg" do %>

    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "components/form_group",
            label: "Email",
            for_id: "user_email",
            hint: "Use your company email when possible — we use the domain to link teammates automatically.",
            required: true,
            error: resource.errors[:email].first do %>
        <%= f.email_field :email, autocomplete: "email", autofocus: true,
              class: input_classes(resource.errors[:email].any?) %>
      <% end %>

      <%= render "components/form_group",
            label: "Password",
            for_id: "user_password",
            hint: "#{Devise.password_length.min} characters minimum",
            required: true,
            error: resource.errors[:password].first do %>
        <%= f.password_field :password, autocomplete: "new-password",
              class: input_classes(resource.errors[:password].any?) %>
      <% end %>

      <%= render "components/form_group",
            label: "Confirm password",
            for_id: "user_password_confirmation",
            required: true,
            error: resource.errors[:password_confirmation].first do %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: input_classes(resource.errors[:password_confirmation].any?) %>
      <% end %>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <%= render "devise/shared/links" %>
        <%= render "components/btn", label: "Create account", type: :submit, variant: :primary %>
      </div>
    <% end %>

    <%= render "devise/shared/omniauth_buttons", title: "Or sign up with" %>
  <% end %>
</div>
