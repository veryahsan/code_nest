<% page_title "Create organisation — Code Nest" %>

<div class="flex justify-center">
  <%= render "components/card",
        title: "Create your organisation",
        description: "You’ll be the organisation admin. You can invite teammates after signing in.",
        extra_class: "w-full max-w-lg" do %>

    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "components/form_group",
            label: "Organisation name",
            for_id: "user_organisation_name",
            hint: "Shown across the app (e.g. your company or team name).",
            required: true,
            error: resource.errors[:organisation_name].first do %>
        <%= f.text_field :organisation_name,
              id: "user_organisation_name",
              autocomplete: "organization",
              class: input_classes(resource.errors[:organisation_name].any?) %>
      <% end %>

      <%= render "components/form_group",
            label: "Email",
            for_id: "user_email",
            required: true,
            error: resource.errors[:email].first do %>
        <%= f.email_field :email, autocomplete: "email",
              class: input_classes(resource.errors[:email].any?) %>
      <% end %>

      <%= render "components/form_group",
            label: "Password",
            for_id: "user_password",
            hint: "#{Devise.password_length.min} characters minimum",
            required: true,
            error: resource.errors[:password].first do %>
        <%= f.password_field :password, autocomplete: "new-password",
              class: input_classes(resource.errors[:password].any?) %>
      <% end %>

      <%= render "components/form_group",
            label: "Confirm password",
            for_id: "user_password_confirmation",
            required: true,
            error: resource.errors[:password_confirmation].first do %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: input_classes(resource.errors[:password_confirmation].any?) %>
      <% end %>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <%= render "devise/shared/links" %>
        <%= render "components/btn", label: "Create organisation", type: :submit, variant: :primary %>
      </div>
    <% end %>
  <% end %>
</div>
