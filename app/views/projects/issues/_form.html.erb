<%= form_with model: issue, url: form_url, method: form_method, scope: :issue, class: "space-y-6" do |f| %>
  <% if issue.errors.any? %>
    <%= render "components/alert",
          variant: :danger,
          title: "#{pluralize(issue.errors.count, 'error')} prevented saving",
          message: issue.errors.full_messages.to_sentence,
          dismissible: false %>
  <% end %>

  <%= render "components/form_group",
        label: "Summary",
        for_id: "issue_summary",
        required: true,
        error: issue.errors[:summary].first do %>
    <%= f.text_field :summary,
          id: "issue_summary",
          autofocus: true,
          class: input_classes(issue.errors[:summary].any?) %>
  <% end %>

  <%= render "components/form_group",
        label: "Description",
        for_id: "issue_description",
        error: issue.errors[:description].first do %>
    <%= f.text_area :description,
          id: "issue_description",
          rows: 5,
          class: input_classes(issue.errors[:description].any?) %>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <%= render "components/form_group",
          label: "Type",
          for_id: "issue_issue_type",
          required: true,
          error: issue.errors[:issue_type].first do %>
      <%= f.select :issue_type,
            Issue.issue_types.keys.map { |k| [k.humanize, k] },
            {},
            id: "issue_issue_type",
            class: input_classes(issue.errors[:issue_type].any?) %>
    <% end %>

    <%= render "components/form_group",
          label: "Status",
          for_id: "issue_status",
          required: true,
          error: issue.errors[:status].first do %>
      <%= f.select :status,
            Issue.statuses.keys.map { |k| [k.humanize, k] },
            {},
            id: "issue_status",
            class: input_classes(issue.errors[:status].any?) %>
    <% end %>

    <%= render "components/form_group",
          label: "Priority",
          for_id: "issue_priority",
          required: true,
          error: issue.errors[:priority].first do %>
      <%= f.select :priority,
            Issue.priorities.keys.map { |k| [k.humanize, k] },
            {},
            id: "issue_priority",
            class: input_classes(issue.errors[:priority].any?) %>
    <% end %>
  </div>

  <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
    <%= link_to "Cancel", project_path(@project), class: "btn-link text-sm font-medium" %>
    <%= render "components/btn", label: submit_label, type: :submit, variant: :primary %>
  </div>
<% end %>
