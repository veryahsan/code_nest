<% page_title "New resource — #{@project.name}" %>

<%= render "components/page_header",
      title: "New remote resource",
      breadcrumbs: [
        { label: "Projects", href: projects_path },
        { label: @project.name, href: project_path(@project) },
        { label: "Resources", href: project_remote_resources_path(@project) },
        { label: "New" },
      ] %>

<div class="flex justify-center">
  <%= render "components/card", extra_class: "w-full max-w-2xl" do %>
    <%= render "projects/remote_resources/form",
          resource: @resource,
          form_url: project_remote_resources_path(@project),
          form_method: :post,
          submit_label: "Add resource" %>
  <% end %>
</div>
