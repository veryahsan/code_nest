<%= form_with model: document, url: form_url, method: form_method, scope: :project_document, class: "space-y-4" do |f| %>
  <% if document.errors.any? %>
    <%= render "components/alert",
          variant: :danger,
          title: "#{pluralize(document.errors.count, 'issue')} prevented saving",
          message: document.errors.full_messages.to_sentence,
          dismissible: false %>
  <% end %>

  <%= render "components/form_group",
        label: "Title",
        for_id: "project_document_title",
        required: true,
        error: document.errors[:title].first do %>
    <%= f.text_field :title,
          id: "project_document_title",
          autofocus: true,
          class: input_classes(document.errors[:title].any?) %>
  <% end %>

  <%= render "components/form_group",
        label: "URL",
        for_id: "project_document_url",
        error: document.errors[:url].first do %>
    <%= f.url_field :url,
          id: "project_document_url",
          class: input_classes(document.errors[:url].any?) %>
  <% end %>

  <%= render "components/form_group",
        label: "External ID",
        for_id: "project_document_external_id",
        error: document.errors[:external_id].first do %>
    <%= f.text_field :external_id,
          id: "project_document_external_id",
          class: input_classes(document.errors[:external_id].any?) %>
  <% end %>

  <%= render "components/form_group",
        label: "Metadata (JSON)",
        for_id: "project_document_metadata",
        hint: "Optional. Must parse to a JSON object.",
        error: document.errors[:metadata].first do %>
    <%= f.text_area :metadata,
          id: "project_document_metadata",
          rows: 6,
          value: (document.metadata.present? ? JSON.pretty_generate(document.metadata) : ""),
          class: input_classes(document.errors[:metadata].any?) + " font-mono text-xs" %>
  <% end %>

  <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
    <%= link_to "Cancel", project_documents_path(@project), class: "btn-link text-sm font-medium" %>
    <%= render "components/btn", label: submit_label, type: :submit, variant: :primary %>
  </div>
<% end %>
