<%# Resources tab: connected APIs and services for the project (showing the
    first few; full management lives on the resources index). %>
<% if @remote_resources.any? %>
  <ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
    <% @remote_resources.each do |r| %>
      <li class="py-4 first:pt-0 flex items-start justify-between gap-3">
        <div>
          <%= link_to r.name, project_remote_resource_path(@project, r),
                class: "text-sm font-medium text-zinc-900 dark:text-zinc-100 hover:underline" %>
          <p class="text-xs text-muted-color"><%= r.url.presence || "No URL" %></p>
        </div>
        <%= badge_tag r.kind, variant: :brand %>
      </li>
    <% end %>
  </ul>
<% else %>
  <%= render "components/empty_state",
        icon: :inbox,
        title: "No resources yet",
        description: "Add an external API or service that this project uses." %>
<% end %>
<div class="mt-6">
  <%= link_to "Manage resources", project_remote_resources_path(@project), class: "btn-link text-sm font-medium" %>
</div>
