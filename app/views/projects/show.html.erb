<% page_title "#{@project.name} — Projects" %>

<%# ── Header: project name + real-data pills + actions ──────────────────── %>
<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
  <div class="min-w-0">
    <h1 class="text-2xl font-semibold tracking-tight text-base-color"><%= @project.name %></h1>
    <% if @project.description.present? %>
      <p class="mt-1 text-sm text-muted-color"><%= @project.description %></p>
    <% end %>

    <div class="mt-3 flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-surface px-2.5 py-1 text-xs font-medium text-base-color">
        <%= user_avatar_tag(@project.lead, css: "h-4 w-4", text: "text-[8px]") if @project.lead %>
        <%= @project.lead ? Conversation.participant_label(@project.lead) : "Unassigned" %>
        <span class="text-muted-color">· Lead</span>
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-surface px-2.5 py-1 text-xs font-medium text-base-color">
        <%= pluralize(@members.size, "member") %>
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-surface px-2.5 py-1 text-xs font-medium text-base-color">
        <%= pluralize(@languages.size, "language") %>
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-surface px-2.5 py-1 text-xs font-medium text-base-color">
        <%= pluralize(@technologies.size, "technology") %>
      </span>
    </div>
  </div>

  <% if policy(@project).update? %>
    <div class="flex shrink-0 flex-wrap items-center gap-2">
      <%= render "components/btn", label: "Edit", href: edit_project_path(@project), variant: :secondary, size: :sm %>
      <%= render "components/btn", label: "Documents", href: project_documents_path(@project), variant: :secondary, size: :sm %>
      <%= render "components/btn", label: "Resources", href: project_remote_resources_path(@project), variant: :secondary, size: :sm %>
    </div>
  <% end %>
</div>

<%# ── Tabs ──────────────────────────────────────────────────────────────── %>
<%
  tab_base     = "border-b-2 px-1 py-3 text-sm font-medium transition-colors -mb-px"
  tab_active   = "text-brand-600 border-brand-600 dark:text-brand-400 dark:border-brand-400"
  tab_inactive = "text-muted-color border-transparent hover:text-base-color"
%>
<div class="mt-6"
     data-controller="tabs"
     data-tabs-active-value="<%= tab_active %>"
     data-tabs-inactive-value="<%= tab_inactive %>">
  <nav class="flex flex-wrap gap-6 border-b border-surface" aria-label="Project sections">
    <% [
         ["overview",  "Overview",  nil],
         ["issues",    "Issues",    @issues.size],
         ["members",   "Members",   @members.size],
         ["documents", "Documents", @documents.size],
         ["resources", "Resources", @remote_resources.size],
       ].each do |name, label, count| %>
      <button type="button"
              role="tab"
              data-tabs-target="tab"
              data-tab-name="<%= name %>"
              data-action="click->tabs#select"
              class="<%= tab_base %> <%= tab_inactive %>">
        <%= label %><% if count %> <span class="text-muted-color">(<%= count %>)</span><% end %>
      </button>
    <% end %>
  </nav>

  <div data-tabs-target="panel" data-tab-panel="overview" class="py-6">
    <%= render "projects/overview" %>
  </div>
  <div data-tabs-target="panel" data-tab-panel="issues" class="hidden py-6">
    <%= render "projects/issues_panel" %>
  </div>
  <div data-tabs-target="panel" data-tab-panel="members" class="hidden py-6">
    <%= render "projects/members_panel" %>
  </div>
  <div data-tabs-target="panel" data-tab-panel="documents" class="hidden py-6">
    <%= render "projects/documents_panel" %>
  </div>
  <div data-tabs-target="panel" data-tab-panel="resources" class="hidden py-6">
    <%= render "projects/resources_panel" %>
  </div>
</div>

<% if policy(@project).destroy? %>
  <div class="mt-8 border-t border-surface pt-6">
    <h4 class="text-xs uppercase tracking-wide text-muted-color mb-3">Danger zone</h4>
    <%= button_to "Delete project",
          project_path(@project),
          method: :delete,
          data: { turbo_confirm: "Delete #{@project.name}? Documents, resources, and tag assignments will all be removed." },
          class: "btn-base btn-danger btn-md" %>
  </div>
<% end %>
