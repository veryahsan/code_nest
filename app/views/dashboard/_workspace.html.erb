<%= render "components/page_header",
      title: "Welcome, #{@facade.greeting_name}",
      description: "Your personal workspace at #{@facade.organisation.name}." %>

<div class="section-stack">
  <div class="flex flex-wrap items-center gap-2">
    <%= badge_tag @facade.role_label, variant: :neutral, dot: true %>
    <% if @facade.job_title.present? %>
      <%= badge_tag @facade.job_title, variant: :brand %>
    <% end %>
    <span class="text-xs text-muted-color font-mono"><%= @facade.organisation.slug %></span>
  </div>

  <div class="card-grid-3">
    <%= render "components/card", title: "Your teams", description: "Teams you belong to" do %>
      <p class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tabular-nums"><%= @facade.teams.size %></p>
    <% end %>
    <%= render "components/card", title: "Your projects", description: "Projects owned by your teams" do %>
      <p class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tabular-nums"><%= @facade.projects.size %></p>
    <% end %>
    <%= render "components/card", title: "Your manager", description: "Who you report to" do %>
      <% if @facade.manager %>
        <p class="text-xl font-semibold text-zinc-900 dark:text-zinc-100"><%= @facade.manager.display_name %></p>
        <% if @facade.manager.job_title.present? %>
          <p class="mt-1 text-xs text-muted-color"><%= @facade.manager.job_title %></p>
        <% end %>
      <% else %>
        <p class="text-xl font-semibold text-muted-color">—</p>
        <p class="mt-1 text-xs text-muted-color">No manager on record.</p>
      <% end %>
    <% end %>
  </div>

  <div class="card-grid-2">
    <%= render "components/card", title: "Your teams" do %>
      <% if @facade.teams.any? %>
        <ul class="divide-y divide-zinc-200 dark:divide-zinc-800 -mx-1">
          <% @facade.teams.each do |team| %>
            <li class="py-3 first:pt-0">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <%= link_to team.name, team_path(team),
                        class: "text-sm font-medium text-zinc-900 dark:text-zinc-100 hover:text-brand-600 dark:hover:text-brand-400" %>
                  <p class="text-xs text-muted-color font-mono mt-0.5"><%= team.slug %></p>
                </div>
                <%= badge_tag "#{team.users.size} #{'member'.pluralize(team.users.size)}", variant: :neutral %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <%= render "components/empty_state",
              icon: :folder,
              title: "You're not on any team yet",
              description: "Ask an organisation admin to add you to a team to see it here." %>
      <% end %>
    <% end %>

    <%= render "components/card", title: "Your projects" do %>
      <% if @facade.projects.any? %>
        <div class="overflow-x-auto -mx-1">
          <table class="w-full text-sm text-left">
            <thead>
              <tr class="text-xs text-muted-color border-b border-zinc-200 dark:border-zinc-800">
                <th class="pb-2 pr-4 font-medium">Name</th>
                <th class="pb-2 pr-4 font-medium">Team</th>
                <th class="pb-2 font-medium">Slug</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
              <% @facade.projects.each do |project| %>
                <tr>
                  <td class="py-2.5 pr-4 font-medium">
                    <%= link_to project.name, project_path(project),
                          class: "text-zinc-900 dark:text-zinc-100 hover:text-brand-600 dark:hover:text-brand-400" %>
                  </td>
                  <td class="py-2.5 pr-4 text-muted-color">
                    <% if project.team %>
                      <%= project.team.name %>
                    <% else %>
                      <span class="italic">Unassigned</span>
                    <% end %>
                  </td>
                  <td class="py-2.5 font-mono text-xs text-muted-color"><%= project.slug %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <%= render "components/empty_state",
              icon: :inbox,
              title: "No projects yet",
              description: "Once your teams own projects, they'll show up here." %>
      <% end %>
    <% end %>
  </div>

  <% if @facade.direct_reports? %>
    <%= render "components/card", title: "Direct reports", description: "People who report to you" do %>
      <ul class="divide-y divide-zinc-200 dark:divide-zinc-800 -mx-1">
        <% @facade.direct_reports.each do |report| %>
          <li class="py-3 first:pt-0 flex items-center justify-between gap-2">
            <div>
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100"><%= report.display_name %></p>
              <p class="text-xs text-muted-color mt-0.5">
                <%= report.user&.email %>
                <% if report.job_title.present? %>
                  · <%= report.job_title %>
                <% end %>
              </p>
            </div>
            <%= link_to "View", employee_path(report),
                  class: "text-xs font-medium text-brand-600 hover:underline" %>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% end %>
</div>
