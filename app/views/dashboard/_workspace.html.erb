<%= render "components/page_header",
      title: "Welcome, #{@facade.greeting_name}",
      description: "Your personal workspace at #{@facade.organisation.name}." %>

<div class="section-stack">
  <div class="flex flex-wrap items-center gap-2">
    <%= badge_tag @facade.role_label, variant: :neutral, dot: true %>
    <% if @facade.job_title.present? %>
      <%= badge_tag @facade.job_title, variant: :brand %>
    <% end %>
    <span class="text-xs text-muted-color font-mono"><%= @facade.organisation.slug %></span>
  </div>

  <div class="card-grid-3">
    <%= render "components/card", title: "Your projects", description: "Projects you belong to" do %>
      <p class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tabular-nums"><%= @facade.projects.size %></p>
    <% end %>
    <%= render "components/card", title: "Messages", description: "Jump into your conversations" do %>
      <%= link_to "Open messages", messages_path, class: "btn-link text-sm font-medium" %>
    <% end %>
    <%= render "components/card", title: "Your manager", description: "Who you report to" do %>
      <% if @facade.manager %>
        <div class="flex items-center gap-3">
          <%= user_avatar_tag(@facade.manager.user, css: "h-10 w-10") %>
          <div class="min-w-0">
            <p class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 truncate"><%= @facade.manager.display_name %></p>
            <% if @facade.manager.job_title.present? %>
              <p class="mt-0.5 text-xs text-muted-color"><%= @facade.manager.job_title %></p>
            <% end %>
          </div>
        </div>
      <% else %>
        <p class="text-xl font-semibold text-muted-color">—</p>
        <p class="mt-1 text-xs text-muted-color">No manager on record.</p>
      <% end %>
    <% end %>
  </div>

  <%= render "components/card", title: "Your projects" do %>
    <% if @facade.projects.any? %>
      <ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
        <% @facade.projects.each do |project| %>
          <li class="py-4 first:pt-0">
            <div class="flex items-start justify-between gap-2">
              <div>
                <%= link_to project.name, project_path(project),
                      class: "text-sm font-medium text-zinc-900 dark:text-zinc-100 hover:text-brand-600 dark:hover:text-brand-400" %>
                <p class="text-xs text-muted-color font-mono mt-0.5"><%= project.slug %></p>
              </div>
              <%= badge_tag "#{project.users.size} #{'member'.pluralize(project.users.size)}", variant: :neutral %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= render "components/empty_state",
            icon: :folder,
            title: "You're not on any project yet",
            description: "Ask an organisation admin to add you to a project to see it here." %>
    <% end %>
  <% end %>

  <% if @facade.direct_reports? %>
    <%= render "components/card", title: "Direct reports", description: "People who report to you" do %>
      <ul class="divide-y divide-zinc-200 dark:divide-zinc-800">
        <% @facade.direct_reports.each do |report| %>
          <li class="py-4 first:pt-0 flex items-center justify-between gap-2">
            <div class="flex items-center gap-3 min-w-0">
              <%= user_avatar_tag(report.user, css: "h-8 w-8") if report.user %>
              <div class="min-w-0">
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate"><%= report.display_name %></p>
                <p class="text-xs text-muted-color mt-0.5">
                  <%= report.user&.email %>
                  <% if report.job_title.present? %>
                    · <%= report.job_title %>
                  <% end %>
                </p>
              </div>
            </div>
            <%= link_to "View", employee_path(report),
                  class: "text-xs font-medium text-brand-600 hover:underline" %>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% end %>
</div>
