<%
  # Optional:
  #   title        main heading   (default: "Nothing here yet")
  #   description  sub-text
  #   icon         :inbox | :search | :folder | :document  (default: :inbox)
  #   action_label label for optional CTA button
  #   action_href  href for CTA button
  #   action_method :get | :post | etc.

  es_title   = local_assigns.fetch(:title, "Nothing here yet")
  es_desc    = local_assigns.fetch(:description, nil)
  icon_name  = local_assigns.fetch(:icon, :inbox).to_sym
  act_label  = local_assigns.fetch(:action_label, nil)
  act_href   = local_assigns.fetch(:action_href, nil)

  icon_paths = {
    inbox:    '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 0 1 2.012 1.244l.256.512a2.25 2.25 0 0 0 2.013 1.244h3.218a2.25 2.25 0 0 0 2.013-1.244l.256-.512a2.25 2.25 0 0 1 2.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H6.911a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661Z" />',
    search:   '<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />',
    folder:   '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />',
    document: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />',
  }
%>

<div class="flex flex-col items-center justify-center py-16 px-4 text-center">
  <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-zinc-100 dark:bg-zinc-800">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
         stroke-width="1.5" stroke="currentColor"
         class="h-7 w-7 text-zinc-400 dark:text-zinc-500">
      <%= (icon_paths[icon_name] || icon_paths[:inbox]).html_safe %>
    </svg>
  </div>

  <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100"><%= es_title %></h3>

  <% if es_desc.present? %>
    <p class="mt-1 text-sm text-muted-color max-w-sm"><%= es_desc %></p>
  <% end %>

  <% if act_label.present? && act_href.present? %>
    <div class="mt-4">
      <%= render "components/btn",
            label: act_label,
            href: act_href,
            variant: :primary,
            size: :sm %>
    </div>
  <% end %>
</div>
