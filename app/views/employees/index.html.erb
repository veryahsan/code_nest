<% page_title "Employees — #{current_organisation.name}" %>

<% if policy(Employee).create? %>
  <% content_for :page_actions do %>
    <%= render "components/btn", label: "Add employee", href: new_employee_path, variant: :primary, size: :sm %>
  <% end %>
<% end %>

<%= render "components/page_header",
      title: "Employees",
      description: "HR profiles for #{current_organisation.name}.",
      breadcrumbs: [
        { label: "Dashboard", href: dashboard_path },
        { label: "Employees" },
      ] %>

<%= render "components/card" do %>
  <% if @employees.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="text-xs text-muted-color border-b border-zinc-200 dark:border-zinc-800">
            <th class="pb-3 pr-4 font-medium">Name</th>
            <th class="pb-3 pr-4 font-medium">Title</th>
            <th class="pb-3 pr-4 font-medium">Manager</th>
            <th class="pb-3 font-medium">Email</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
          <% @employees.each do |emp| %>
            <tr>
              <td class="py-3.5 pr-4 font-medium text-zinc-900 dark:text-zinc-100">
                <div class="flex items-center gap-3">
                  <%= user_avatar_tag(emp.user, css: "h-8 w-8") %>
                  <%= link_to (emp.display_name.presence || emp.user.email), employee_path(emp), class: "hover:underline truncate" %>
                </div>
              </td>
              <td class="py-3.5 pr-4 text-muted-color"><%= emp.job_title.presence || "—" %></td>
              <td class="py-3.5 pr-4 text-muted-color">
                <% if emp.manager&.user %>
                  <div class="flex items-center gap-2">
                    <%= user_avatar_tag(emp.manager.user, css: "h-6 w-6") %>
                    <span class="truncate"><%= emp.manager.display_name.presence || emp.manager.user.email %></span>
                  </div>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="py-3.5 text-muted-color"><%= emp.user.email %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= pagination_tag(@pagy) %>
  <% else %>
    <%= render "components/empty_state",
          icon: :inbox,
          title: "No employees yet",
          description: "Add HR profiles for the people in your organisation." %>
  <% end %>
<% end %>
