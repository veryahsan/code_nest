<% page_title "Code Nest" %>

<%= render "components/page_header",
      title: "Organise projects, teams, and knowledge",
      description: "A workspace for your organisation’s engineering footprint — projects, languages, technologies, and documents in one place." %>

<div class="section-stack">
  <div class="card-grid-3">
    <%= render "components/card", title: "Multi-tenant by design", shadow: true do %>
      <p class="text-sm text-muted-color">
        Each customer organisation is isolated. Invite teammates, structure teams, and ship without stepping on other tenants’ data.
      </p>
    <% end %>

    <%= render "components/card", title: "Projects that reflect reality", shadow: true do %>
      <p class="text-sm text-muted-color">
        Track languages, stacks, remote resources, and links to docs — so onboarding and audits stay grounded in what you actually run.
      </p>
    <% end %>

    <%= render "components/card", title: "Built for operators", shadow: true do %>
      <p class="text-sm text-muted-color">
        Platform staff use Active Admin; everyone else signs in here. Same visual language end to end via shared Tailwind components.
      </p>
    <% end %>
  </div>
</div>
