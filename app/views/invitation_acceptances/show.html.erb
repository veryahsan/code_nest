<% page_title "Accept invitation — #{@invitation.organisation.name}" %>

<%= render "components/page_header",
      title: "You're invited to #{@invitation.organisation.name}",
      description: "Confirm to join as a #{@invitation.invite_admin? ? 'administrator' : 'member'}." %>

<div class="flex justify-center">
  <%= render "components/card", extra_class: "w-full max-w-lg" do %>
    <%= form_with url: submit_invitation_acceptance_path(@invitation.token),
          method: :post,
          scope: :invitation_acceptance,
          class: "space-y-4" do |f| %>
      <p class="text-sm text-zinc-700 dark:text-zinc-300">
        Email: <strong><%= @invitation.email %></strong>
      </p>

      <% if @existing_user %>
        <p class="text-sm text-muted-color">
          We found an existing account. Sign in below to accept and link your account to <%= @invitation.organisation.name %>.
        </p>
      <% else %>
        <%= render "components/form_group",
              label: "Choose a password",
              for_id: "invitation_acceptance_password",
              required: true do %>
          <%= f.password_field :password,
                id: "invitation_acceptance_password",
                autocomplete: "new-password",
                autofocus: true,
                class: input_classes %>
        <% end %>
      <% end %>

      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <%= link_to "Cancel", root_path, class: "btn-link text-sm font-medium" %>
        <%= render "components/btn", label: "Accept invitation", type: :submit, variant: :primary %>
      </div>
    <% end %>
  <% end %>
</div>
